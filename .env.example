# ASR 转写凭据。复制为 .env 并填入你自己的值；.env 已被 .gitignore 排除，不会入库。
# 默认 ASR 走 video2md（内置 bin/mp4-md 二进制），音频临时中转用 DashScope 自带文件空间，
# 只需要下面这一个 Key，无需自建 OSS。

# 阿里云 DashScope（百炼）API Key：https://bailian.console.aliyun.com/ 右上角 API-KEY
DASHSCOPE_API_KEY=

# 可选：DashScope 热词表 ID（提升专有名词识别准确率，没有可留空）。
ASR_BASE_VOCABULARY_ID=

# ── 以下仅旧版 ASR 路径需要 ──────────────────────────────────────────────
# 只有显式用 `--asr-script scripts/transcribe_media_recorded.sh` 走旧的自建 OSS 方案时才需要；
# 默认 video2md 路径无需填写。
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
